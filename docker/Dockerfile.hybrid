# Dockerfile for vLLM with Hybrid INT4+FP8 dispatch patch
#
# Build from the repo root:
#   docker build -t vllm-qwen35-hybrid -f docker/Dockerfile.hybrid .
#
# The base image must be a vLLM 0.19.x image compiled for SM121 (Blackwell).
# Replace the FROM line with your actual base image.

FROM vllm-qwen35-v019:latest

# Apply hybrid INT4+FP8 dispatch patch to INCConfig
# Option A: Copy the pre-patched file (recommended)
COPY patches/01-hybrid-int4-fp8/inc.py \
     /usr/local/lib/python3.12/dist-packages/vllm/model_executor/layers/quantization/inc.py

# Option B: Apply the patch (alternative — uncomment if you prefer diffs)
# COPY patches/01-hybrid-int4-fp8/inc.py.patch /tmp/inc.py.patch
# RUN cd /usr/local/lib/python3.12/dist-packages/vllm/model_executor/layers/quantization && \
#     patch -p1 < /tmp/inc.py.patch && \
#     rm /tmp/inc.py.patch

# Restore entrypoint (vLLM image default)
ENTRYPOINT ["vllm"]
CMD ["serve", "--help"]
